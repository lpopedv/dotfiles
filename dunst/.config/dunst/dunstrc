[global]
    ### Display ###
    monitor      = 0
    follow       = none
    origin       = top-right
    offset       = (16, 16)

    ### Geometry ###
    width        = 370
    height       = (0, 200)
    gap_size     = 8

    ### Text ###
    font            = JetBrainsMono Nerd Font 11
    line_height     = 2
    markup          = full
    format          = "<b>%s</b>\n%b"
    alignment       = left
    vertical_alignment = center
    word_wrap       = yes
    ellipsize       = middle
    show_age_threshold = -1

    ### Icons ###
    icon_theme      = Adwaita
    enable_recursive_icon_lookup = true
    icon_position   = left
    min_icon_size   = 32
    max_icon_size   = 48

    ### Appearance ###
    corner_radius       = 12
    frame_width         = 1
    padding             = 12
    horizontal_padding  = 14
    text_icon_padding   = 10

    ### Progress bar ###
    progress_bar                = true
    progress_bar_height         = 4
    progress_bar_frame_width    = 0
    progress_bar_min_width      = 150
    progress_bar_max_width      = 340
    progress_bar_corner_radius  = 2

    ### Behavior ###
    show_indicators     = no
    sort                = yes
    idle_threshold      = 0
    sticky_history      = yes
    history_length      = 20
    always_run_script   = true
    ignore_newline      = no
    hide_duplicate_count = false
    ignore_dbusclose    = false
    force_xwayland      = false

    ### Timeouts ###
    browser = /usr/bin/xdg-open

[urgency_low]
    background  = "#0d0d0dc8"
    foreground  = "#6b6b6bff"
    frame_color = "#ffffff10"
    timeout     = 4
    highlight   = "#6b6b6bff"

[urgency_normal]
    background  = "#0d0d0dc8"
    foreground  = "#c8c8c8ff"
    frame_color = "#ffffff18"
    timeout     = 5
    highlight   = "#e8e8e8ff"

[urgency_critical]
    background  = "#0d0d0dc8"
    foreground  = "#c8c8c8ff"
    frame_color = "#f7768e55"
    timeout     = 0
    highlight   = "#f7768eff"
